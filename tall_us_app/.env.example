# =============================================================================
# Tall Us - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Appwrite Configuration
# -----------------------------------------------------------------------------
# Get these from https://cloud.appwrite.io
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here
APPWRITE_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Appwrite Database & Storage
# -----------------------------------------------------------------------------
APPWRITE_DATABASE_ID=tall_us_db
APPWRITE_STORAGE_BUCKET_ID=tall-us-photos

# -----------------------------------------------------------------------------
# Stripe Payments (for premium subscriptions)
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_MONTHLY_PRICE_ID=price_monthly_xxx
STRIPE_YEARLY_PRICE_ID=price_yearly_xxx

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (for push notifications)
# -----------------------------------------------------------------------------
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# -----------------------------------------------------------------------------
# Courier (for email notifications)
# -----------------------------------------------------------------------------
COURIER_AUTH_TOKEN=pk_prod_xxx
COURIER_BRAND_ID=your_brand_id

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=Tall Us
APP_URL=https://tallus.com
APP_ENV=development

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_STRIPE_PAYMENTS=false
ENABLE_HEIGHT_VERIFICATION=false
